# ─── GatePlay — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Supabase PostgreSQL ───────────────────────────────────────────────────────
# Get this from: Supabase dashboard → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get these from: clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe Payments (optional) ────────────────────────────────────────────────
# Get these from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated allowed origins for production
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com